# ─────────────────────────────────────────────────────────────────────────────
# Linux Privilege Escalation Toolkit — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is listed in .gitignore and will NEVER be committed to Git.
# ─────────────────────────────────────────────────────────────────────────────


# ── NVD API Key (optional but recommended) ────────────────────────────────────
# Without a key: 5 requests / 30 s (unauthenticated rate limit)
# With a key:   50 requests / 30 s — much faster CVE updates
# Get a free key at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=


# ── Web dashboard server ──────────────────────────────────────────────────────
# Host and port for the FastAPI web server
# Default: 0.0.0.0:8765  (accessible on all network interfaces)
WEB_HOST=0.0.0.0
WEB_PORT=8765

# Set to "true" to enable uvicorn --reload (development only)
WEB_DEBUG=false


# ── Data directory ────────────────────────────────────────────────────────────
# Where scan results and the SQLite database are stored
# Default: ./data  (relative to project root)
# DATA_DIR=./data


# ── Output directory ──────────────────────────────────────────────────────────
# Where generated HTML/PDF/TXT reports are saved by the CLI
# Default: ./output
# OUTPUT_DIR=./output
